# Ollama (локальные модели; должен быть запущен: ollama serve)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=qwen2.5-coder:7b

# ChromaDB (путь к данным; пусто = vectors/chroma_db в корне проекта)
CHROMA_PERSIST_DIR=
CHROMA_COLLECTION=rag_collection

# Размерность векторов (для nomic-embed-text = 1024)
VECTOR_SIZE=1024

# Пути (опционально, относительно корня проекта)
# DOCS_PATH=docs
# VECTORS_PATH=vectors
