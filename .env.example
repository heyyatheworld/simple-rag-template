# Ollama — project env (all OLLAMA_*)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large:latest
OLLAMA_LLM_MODEL=llama3.2
# Max chars per text for embed (long texts are split; one doc per request)
# OLLAMA_EMBED_MAX_DOC_CHARS=500

# Chroma add_documents batch size during indexing (default 32)
# OLLAMA_INDEX_BATCH_SIZE=32
# OLLAMA_RETRIEVER_K=5
# OLLAMA_LLM_TEMPERATURE=0
# OLLAMA_CHUNK_SIZE=1000
# OLLAMA_CHUNK_OVERLAP=200
# OLLAMA_TIKTOKEN_ENCODING=cl100k_base

# Optional: override default prompt (absolute path or path relative to project root)
# OLLAMA_PROMPT_PATH=prompts/answer.txt

OLLAMA_CHROMA_PERSIST_DIR=
OLLAMA_CHROMA_COLLECTION=rag_collection
OLLAMA_VECTOR_SIZE=1024

OLLAMA_DOCS_PATH=data
OLLAMA_VECTORS_PATH=vectors
