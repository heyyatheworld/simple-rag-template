# Ollama — project env (all OLLAMA_*)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large:latest
OLLAMA_LLM_MODEL=llama3.2
# Max chars per text for embed (long texts are split; one doc per request)
# OLLAMA_EMBED_MAX_DOC_CHARS=500

OLLAMA_CHROMA_PERSIST_DIR=
OLLAMA_CHROMA_COLLECTION=rag_collection
OLLAMA_VECTOR_SIZE=1024

OLLAMA_DOCS_PATH=data
OLLAMA_VECTORS_PATH=vectors
