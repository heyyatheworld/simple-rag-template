# OpenAI (обязательно для embeddings и LLM)
OPENAI_API_KEY=sk-...

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_collection

# Модели OpenAI (опционально)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# Размерность векторов (должна соответствовать выбранной модели embeddings, для text-embedding-3-small = 1536)
VECTOR_SIZE=1536

# Пути (опционально, относительно корня проекта)
# DOCS_PATH=docs
# VECTORS_PATH=vectors
