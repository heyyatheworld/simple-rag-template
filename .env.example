# OpenAI (обязательно для embeddings и LLM)
OPENAI_API_KEY=sk-...

# ChromaDB (путь к данным; пусто = vectors/chroma_db в корне проекта)
CHROMA_PERSIST_DIR=
CHROMA_COLLECTION=rag_collection

# Модели OpenAI (опционально)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# Размерность векторов (должна соответствовать выбранной модели embeddings, для text-embedding-3-small = 1536)
VECTOR_SIZE=1536

# Пути (опционально, относительно корня проекта)
# DOCS_PATH=docs
# VECTORS_PATH=vectors
